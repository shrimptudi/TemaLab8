    printf("2. X: Craiova, Y: Iasi\n");
    dijkstra(graph, 3, 6); // De la 3(Craiova) la 6(Iasi)

    printf("3. X: Constanta, Y: Cluj-Napoca\n");
    dijkstra(graph, 7, 1); // De la 7(Constanta) la 1(Cluj-Napoca)

    return 0;
}
