#include <stdio.h>
#include <limits.h>
#include <stdbool.h>

#define V 8 // Avem 8 orase in total pe harta

// Mapam indexul fiecarui nod la numele orasului
const char* orase[] = {
    "Timisoara",    // 0
    "Cluj-Napoca",  // 1
    "Sibiu",        // 2
    "Craiova",      // 3
    "Bucuresti",    // 4
    "Brasov",       // 5
    "Iasi",         // 6
    "Constanta"     // 7
};

// Gaseste nodul cu distanta minima dintre cele neexplorate
int minDistance(int dist[], bool sptSet[]) {
    int min = INT_MAX, min_index = -1;
    
    for (int v = 0; v < V; v++)
        if (sptSet[v] == false && dist[v] <= min) {
            min = dist[v];
            min_index = v;
        }
        
    return min_index;
}

// Functie recursiva pentru a afisa ruta folosind vectorul de parinti
void printPath(int parent[], int j) {
    // Daca am ajuns la sursa, ne oprim
    if (parent[j] == -1)
        return;
        
    printPath(parent, parent[j]);
    printf(" -> %s", orase[j]);
}

// Algoritmul Dijkstra pentru a gasi drumul de la src la dest
void dijkstra(int graph[V][V], int src, int dest) {
    int dist[V];      // Retine cea mai scurta distanta posibila
    bool sptSet[V];   // Marcheaza nodurile deja explorate
    int parent[V];    // Retine traseul pentru a putea reconstrui ruta la final

    // Initializari
    for (int i = 0; i < V; i++) {
        parent[i] = -1;
        dist[i] = INT_MAX;
        sptSet[i] = false;
    }

    dist[src] = 0;

    // Cautam cel mai scurt drum
    for (int count = 0; count < V - 1; count++) {
        int u = minDistance(dist, sptSet);
        sptSet[u] = true; // Marcam nodul ca explorat

        // Actualizam distantele pentru vecinii nodului u
        for (int v = 0; v < V; v++) {
            if (!sptSet[v] && graph[u][v] && dist[u] != INT_MAX 
                && dist[u] + graph[u][v] < dist[v]) {
                parent[v] = u; // Salvam muchia folosita pentru traseu
                dist[v] = dist[u] + graph[u][v];
            }
        }
    }

    // Afisare rezultate fix pe formatul cerut in exercitiu
    printf("Ruta: %s", orase[src]);
    printPath(parent, dest);
    printf("\nKm parcursi in total: %d km\n\n", dist[dest]);
}

