    int graph[V][V] = {0}; // Matricea de adiacenta plina cu 0 initial

    // --- Incarcam harta cu distantele reale din imagine (graf neorientat) ---
    graph[0][1] = graph[1][0] = 319; // Timisoara - Cluj-Napoca
    graph[0][2] = graph[2][0] = 271; // Timisoara - Sibiu
    graph[0][3] = graph[3][0] = 336; // Timisoara - Craiova
    graph[0][4] = graph[4][0] = 550; // Timisoara - Bucuresti
    
    graph[1][2] = graph[2][1] = 176; // Cluj-Napoca - Sibiu
    graph[1][6] = graph[6][1] = 480; // Cluj-Napoca - Iasi
    
    graph[2][5] = graph[5][2] = 120; // Sibiu - Brasov
    graph[2][4] = graph[4][2] = 300; // Sibiu - Bucuresti
    graph[2][6] = graph[6][2] = 460; // Sibiu - Iasi
    
    graph[3][4] = graph[4][3] = 235; // Craiova - Bucuresti
    
    graph[4][5] = graph[5][4] = 170; // Bucuresti - Brasov
    graph[4][7] = graph[7][4] = 250; // Bucuresti - Constanta
    
    graph[5][6] = graph[6][5] = 300; // Brasov - Iasi
    graph[5][7] = graph[7][5] = 200; // Brasov - Constanta
    
    graph[6][7] = graph[7][6] = 400; // Iasi - Constanta

    // --- Executam cele 3 cerinte din Exercițiul Extra ---
    printf("1. X: Timisoara, Y: Constanta\n");
